# Local defaults for `uv run python app.py`.
IMSIM_HOST=127.0.0.1
IMSIM_PORT=8050

# Compose-only PostgreSQL defaults. These are only used by the bundled `db` service.
IMSIM_POSTGRES_DB=imsim
IMSIM_POSTGRES_USER=imsim
IMSIM_POSTGRES_PASSWORD=imsim

# Optional academy shortcut for local demos or tests.
# IMSIM_CHEAT_UNLOCK_PASSWORD=change-me

# Set this for any shared, homelab, or internet-facing deployment to enable the maintenance API.
# IMSIM_ADMIN_TOKEN=

# Optional Gunicorn tuning for container and Procfile deployments.
IMSIM_GUNICORN_WORKERS=4
IMSIM_GUNICORN_THREADS=2
