# Standalone IMSim deployment example.
IMSIM_IMAGE=ghcr.io/schmidtcode/imsim:latest

# Bundled PostgreSQL service settings.
IMSIM_POSTGRES_DB=imsim
IMSIM_POSTGRES_USER=imsim
IMSIM_POSTGRES_PASSWORD=replace-with-a-long-random-password

# Set this before exposing IMSim to other people or to the internet.
IMSIM_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Optional academy shortcut for demos.
# IMSIM_CHEAT_UNLOCK_PASSWORD=change-me

# Keep uploads modest on a public deployment.
IMSIM_MAX_UPLOAD_BYTES=5242880

# Optional Gunicorn tuning.
IMSIM_GUNICORN_WORKERS=4
IMSIM_GUNICORN_THREADS=2
