# Source checkout example. Copy this file to the repo root as `.env`.
IMSIM_HOST=127.0.0.1
IMSIM_PORT=8050

# Compose-only PostgreSQL defaults for `deploy/source/docker-compose.yml`.
IMSIM_POSTGRES_DB=imsim
IMSIM_POSTGRES_USER=imsim
IMSIM_POSTGRES_PASSWORD=imsim

# Optional academy shortcut for local demos or tests.
# IMSIM_CHEAT_UNLOCK_PASSWORD=change-me

# Set this before exposing IMSim to other people or to the internet.
# IMSIM_ADMIN_TOKEN=

# Optional Gunicorn tuning for container deploys.
IMSIM_GUNICORN_WORKERS=4
IMSIM_GUNICORN_THREADS=2
